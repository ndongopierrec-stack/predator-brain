# Predator Brain — Variables d'environnement Railway
# Copier et renseigner dans Railway > Variables

# Base de données (Railway PostgreSQL auto-injecte DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/predator_brain

# APIs données sportives (légales)
THE_ODDS_API_KEY=your_key_here
FOOTBALL_DATA_API_KEY=your_key_here
API_FOOTBALL_KEY=your_key_here

# URL du frontend (pour CORS)
FRONTEND_URL=https://predator-brain-web.up.railway.app

# Bankroll par défaut
DEFAULT_BANKROLL=10000
KELLY_FRACTION=0.25
MAX_STAKE_PCT=0.05

# Environnement
ENVIRONMENT=production
PORT=8001
